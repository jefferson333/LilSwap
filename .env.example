APP_NAME=LilSwap
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.lilswap.xyz
# Optional: Comma-separated list of allowed origins or hostnames (e.g. your ngrok URLs or local IP)
APP_ALLOWED_ORIGINS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=lilswap
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_EXPIRE_ON_CLOSE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contact@lilswap.xyz"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
ALCHEMY_API_KEY=
API_URL=https://api.lilswap.xyz/v1
API_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_STRING
VITE_REOWN_PROJECT_ID=

# Soft anti-abuse guard (progressive delay, no hard block)
SOFT_GUARD_ENABLED=false
SOFT_GUARD_WINDOW_SEC=60
SOFT_GUARD_THRESHOLD=90
SOFT_GUARD_MAX_DELAY_MS=800

# Internal signing (production baseline)
SIGNING_V2_ENABLED=true

# Anonymous proxy session policy
PROXY_REQUIRE_ANON_SESSION=true
PROXY_WALLET_SWITCH_WINDOW_SEC=300
PROXY_WALLET_SWITCH_MAX=20
